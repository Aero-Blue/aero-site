---
import MenuLink from '@/components/MenuLink.astro'
import { Icon } from 'astro-icon/components'
import { SITE_NAV_LINKS, SITE_TITLE } from '@/consts'
---

<header>
  <nav class="navbar bg-base-100 border-base-300 border-b text-xl shadow-sm">
    <div class="flex-none">
      <div class="dropdown">
        <div class="btn btn-ghost sm:hidden" role="button" tabindex="0">
          <Icon name="lucide:menu" size="20" />
        </div>
        <ul
          class="menu menu-sm dropdown-content bg-base-200 rounded-box z-1 mt-3 w-56 p-2 shadow"
          tabindex="-1">
          {SITE_NAV_LINKS.map((link) => <MenuLink href={link.href}>{link.name}</MenuLink>)}
        </ul>
      </div>
    </div>
    <div class="flex-1">
      <a class="btn btn-ghost text-xl" href="/">
        {SITE_TITLE}
      </a>
    </div>
    <div class="navbar-end hidden sm:flex">
      <ul class="menu menu-horizontal">
        {SITE_NAV_LINKS.map((link) => <MenuLink href={link.href}>{link.name}</MenuLink>)}
        <label class="swap swap-rotate hover:text-accent mx-2">
          <input type="checkbox" class="theme-controller" value="light" />
          <Icon name="lucide:sun" class="swap-off fill-current" size="20" />
          <Icon name="lucide:moon" class="swap-on fill-current" size="20" />
        </label>
      </ul>
    </div>
  </nav>
</header>
