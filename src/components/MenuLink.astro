---
interface Props {
  href?: string
  class?: string
}

const { href = '#', class: className = '' } = Astro.props
const pathname = Astro.url.pathname
const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href)
---

<li>
  <a class:list={[className, { 'menu-active': isActive }]} href={href}>
    <slot />
  </a>
</li>
