---
import { getCollection } from 'astro:content'
import BlogPostCard from '@/components/BlogPostCard.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.datePublished.valueOf() - a.data.datePublished.valueOf()
)
const title = 'Blog'
const description = 'Random thoughts and ideas from yet another developer.'
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-12">
    <header class="mb-12 text-center">
      <h1 class="mb-4 text-4xl font-bold md:text-5xl lg:text-6xl">{title}</h1>
      <p class="text-base-content/70 mx-auto mb-4 max-w-2xl text-lg md:text-xl">
        {description}
      </p>
      {posts.length == 0 && <p>No posts yet...</p>}
    </header>
    <div
      class="mx-auto grid max-w-md grid-cols-1 justify-items-center gap-6 sm:max-w-5xl sm:grid-cols-2 md:gap-8 lg:grid-cols-3">
      {posts.map((post) => <BlogPostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
