---
import BlogPostCard from '@/components/BlogPostCard.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getPublishedPosts } from '@/utils/posts'

const posts = await getPublishedPosts()
const title = 'Blog'
const description = 'Random thoughts and ideas from yet another developer.'
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-12">
    <header class="mb-12 text-center">
      <h1 class="mb-4 text-4xl font-bold md:text-5xl lg:text-6xl">{title}</h1>
      <p class="text-base-content/70 mx-auto mb-4 max-w-2xl text-lg md:text-xl">
        {description}
      </p>
      {!posts.length && <p>No posts yet...</p>}
    </header>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <BlogPostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
